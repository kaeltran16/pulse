# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Swift source files
*.swift text eol=lf
*.h text eol=lf
*.m text eol=lf
*.mm text eol=lf

# Xcode project files
# merge=union prevents spurious conflicts in pbxproj
*.pbxproj text eol=lf merge=union
*.xcscheme text eol=lf
*.xcworkspacedata text eol=lf
*.xcsettings text eol=lf
*.xcconfig text eol=lf
*.storekit text eol=lf
*.intentdefinition text eol=lf

# Config / data
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.plist text eol=lf
*.entitlements text eol=lf

# Binary assets — diff and merge disabled
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.pdf binary
*.zip binary
*.ipa binary
*.a binary
*.framework binary
*.xcframework binary
*.dylib binary
