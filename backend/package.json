{
  "name": "pulse-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/backend/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/cli/migrate.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "imapflow": "^1.0.176",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.2",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2",
    "vitest": "^2.1.4"
  }
}
